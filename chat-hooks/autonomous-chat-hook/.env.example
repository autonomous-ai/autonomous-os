# Autonomous BE MQTT broker
AUTONOMOUS_MQTT_URL=tls://broker.autonomous.ai:8883
AUTONOMOUS_MQTT_USERNAME=
AUTONOMOUS_MQTT_PASSWORD=

# Topic to subscribe for incoming chat messages from autonomous web users.
# BE publishes here when a user sends a message via the autonomous web UI.
AUTONOMOUS_MQTT_TOPIC=lamp/+/chat

# Optional. If empty, a random "autonomous-chat-<hex>" client id is used.
AUTONOMOUS_MQTT_CLIENT_ID=

# Forward target on the lamp's local HTTP API.
LAMP_SENSING_URL=http://127.0.0.1:5000/api/sensing/event

# Sensing event type. Matches voice/voice_command so SOUL.md routes it like
# a spoken turn. Override only if BE-driven chat should follow a different path.
AUTONOMOUS_SENSING_TYPE=voice
