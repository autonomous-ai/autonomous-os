# --- DL Backend: All Models Enabled ---
# Tuned for NVIDIA RTX A5000 (24 GB VRAM), all models loaded simultaneously.
# With ~12 ONNX models resident, base VRAM usage is ~14-16 GB.
# Batch sizes are conservative to avoid OOM under concurrent load.

# Auth
DL_API_KEY=changeme
DL_BACKEND_URL=http://localhost:8001

# --- Action recognition ---
# Models: uniformerv2, x3d, videomae
# UniformerV2 fp32: ~3 GB model weight, large per-sample activations
ACTION__ENABLED=true
ACTION__MODEL=uniformerv2
# ACTION__CKPT_PATH=/path/to/model.onnx
# ACTION__REMOTE_URL=https://...
# ACTION__CONFIDENCE_THRESHOLD=0.3
# ACTION__MAX_FRAMES=16
# ACTION__FRAME_INTERVAL=1.0
# ACTION__W=256
# ACTION__H=256
ACTION__BATCH_SIZE=1
ACTION__BATCH_TIMEOUT=0.05

# --- Facial emotion recognition (FER) ---
# Models: posterv2, emonet_8, emonet_5
# PosterV2: ~50 MB model, lightweight 224x224 input
FER__ENABLED=true
FER__MODEL=posterv2
# FER__CKPT_PATH=/path/to/posterv2_7cls.onnx
# FER__REMOTE_URL=https://...
# FER__CONFIDENCE_THRESHOLD=0.5
# FER__FRAME_INTERVAL=1.0
FER__BATCH_SIZE=8
FER__BATCH_TIMEOUT=0.05

# --- Speech emotion recognition (SER) ---
# Models: emotion2vec
# emotion2vec: ~300 MB model, variable-length audio input
SER__ENABLED=true
SER__MODEL=emotion2vec
# SER__CKPT_PATH=/path/to/emotion2vec.onnx
# SER__REMOTE_URL=https://...
# SER__LABELS_PATH=/path/to/labels.txt
SER__BATCH_SIZE=4
SER__BATCH_TIMEOUT=0.05

# --- Pose estimation (2D + 3D + ergonomics) ---
# Models: rtmpose
# 3D lifters: tcpformer (omit to disable)
# Ergo assessors: rula (omit to disable)
# RTMPose: ~30 MB model, small 256x192 input
# TCPFormer: ~10 MB model, tiny keypoint input
POSE__ENABLED=true
POSE__MODEL=rtmpose
POSE__LIFTER_3D=tcpformer
POSE__ERGO_ASSESSOR=rula
# POSE__CKPT_PATH=/path/to/rtmpose-m.onnx
# POSE__REMOTE_URL=https://...
# POSE__CONFIDENCE_THRESHOLD_2D=0.3
# POSE__MIN_VALID_KEYPOINTS=5
# POSE__ERGO_CONFIDENCE_THRESHOLD=0.3
# POSE__LIFTER_3D_CKPT_PATH=/path/to/tcpformer_h36m_243.onnx
# POSE__LIFTER_3D_REMOTE_URL=https://...
# POSE__LIFTER_3D_FRAME_W=1920
# POSE__LIFTER_3D_FRAME_H=1080
POSE__BATCH_SIZE=8
POSE__BATCH_TIMEOUT=0.05

# --- Person detector (used by action recognition) ---
# YOLO12x: ~200 MB model, 640x640 input
PERSON_DETECTOR__ENABLED=true
PERSON_DETECTOR__MODEL=yolo
# PERSON_DETECTOR__MODEL_NAME=yolo12x.pt
# PERSON_DETECTOR__CONFIDENCE_THRESHOLD=0.4
# PERSON_DETECTOR__BBOX_EXPAND_SCALE=2.0
# PERSON_DETECTOR__MIN_AREA_RATIO=0.25
PERSON_DETECTOR__BATCH_SIZE=2
PERSON_DETECTOR__BATCH_TIMEOUT=0.05

# --- Audio embedder (speaker) ---
# Models: ecapa-tdnn1024, resnet34, campplus
# ECAPA-TDNN: ~50 MB model, small mel-feature input
AUDIO_EMBEDDER__ENABLED=true
AUDIO_EMBEDDER__MODEL=ecapa-tdnn1024
# AUDIO_EMBEDDER__MODEL_PATH=/path/to/model.onnx
# AUDIO_EMBEDDER__REMOTE_URL=https://...
AUDIO_EMBEDDER__BATCH_SIZE=8
AUDIO_EMBEDDER__BATCH_TIMEOUT=0.05
# AUDIO_EMBEDDER__PROCESSOR__TARGET_SAMPLE_RATE=16000
# AUDIO_EMBEDDER__PROCESSOR__ENABLE_RESAMPLE=true
# AUDIO_EMBEDDER__PROCESSOR__ENABLE_HIGH_PASS=true
# AUDIO_EMBEDDER__PROCESSOR__HIGH_PASS_CUTOFF_HZ=80.0
# AUDIO_EMBEDDER__PROCESSOR__ENABLE_NOISE_REDUCE=true
# AUDIO_EMBEDDER__PROCESSOR__NOISE_REDUCE_STATIONARY=false
# AUDIO_EMBEDDER__PROCESSOR__ENABLE_VAD=true
# AUDIO_EMBEDDER__PROCESSOR__VAD_MIN_DURATION_SEC=0.5
# AUDIO_EMBEDDER__PROCESSOR__VAD_MIN_VOICE_RATIO=0.4
# AUDIO_EMBEDDER__PROCESSOR__ENABLE_RMS_NORMALIZE=true
# AUDIO_EMBEDDER__PROCESSOR__RMS_TARGET=0.1

# --- Object detection (opt-in per detector) ---
# Endpoints: POST /api/dl/{name}, POST /api/dl/object-detect/{name}
#            WS   /api/dl/object-detection/{name}/ws
# YOLO-World: ~500 MB model, 640x640 input + CLIP text encoder
OBJECT_DETECTOR__YOLO_WORLD__ENABLED=true
# OBJECT_DETECTOR__YOLO_WORLD__USE_ONNX=true
# OBJECT_DETECTOR__YOLO_WORLD__MODEL_PATH=
# OBJECT_DETECTOR__YOLO_WORLD__REMOTE_URL=
# OBJECT_DETECTOR__YOLO_WORLD__CLASSES_PATH=/path/to/classes.txt
# OBJECT_DETECTOR__YOLO_WORLD__THRESHOLD=0.25
OBJECT_DETECTOR__YOLO_WORLD__BATCH_SIZE=2
OBJECT_DETECTOR__YOLO_WORLD__BATCH_TIMEOUT=0.05

# OWLv2: ~600 MB model, 960x960 input + text encoder
OBJECT_DETECTOR__OWLV2__ENABLED=true
# OBJECT_DETECTOR__OWLV2__USE_ONNX=true
# OBJECT_DETECTOR__OWLV2__MODEL_PATH=
# OBJECT_DETECTOR__OWLV2__REMOTE_URL=
# OBJECT_DETECTOR__OWLV2__THRESHOLD=0.1
OBJECT_DETECTOR__OWLV2__BATCH_SIZE=1
OBJECT_DETECTOR__OWLV2__BATCH_TIMEOUT=0.05

# --- Load balancer (master node) ---
LB__BACKENDS=http://127.0.0.1:8001
# LB__HOST=0.0.0.0
# LB__PORT=7999
# LB__INTERNAL_PREFIX=/_internal
# LB__HTTP_TIMEOUT=120.0
# LB__WS_OPEN_TIMEOUT=120.0

# --- Encryption (RSA + AES-256-GCM) ---
# CRYPTO__ENABLED=true
# CRYPTO__KEY_DIR=/root/local/keys
# CRYPTO__KEY_SIZE=2048
# CRYPTO__REQUIRE_ENCRYPTION=false

# --- Cache & CDN ---
# CACHE_DIR=~/.cache/dlbackend
# MODEL_CACHE_DIR=~/.cache/dlbackend/models
# CDN_BASE=https://storage.googleapis.com/autonomous-models
