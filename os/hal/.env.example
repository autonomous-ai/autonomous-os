# HAL Runtime — Environment Variables

# --- Original LeLamp (main.py with LiveKit + OpenAI) ---
OPENAI_API_KEY=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Lamp server.py (FastAPI) ---
# production (default): bind 127.0.0.1, reject non-local requests.
# developer: bind 0.0.0.0, allow all — for local dev/testing only.
#HAL_MODE=production
HAL_SERVO_PORT=/dev/ttyACM0
HAL_LAMP_ID=lamp
HAL_SERVO_FPS=30
HAL_SERVO_HOLD_S=3.0
HAL_HTTP_PORT=5001
HAL_CAMERA_INDEX=0
HAL_CAMERA_WIDTH=640
HAL_CAMERA_HEIGHT=480
#HAL_LOG_LEVEL=INFO
#HAL_LOG_DIR=/var/log/hal
#HAL_DEFAULT_USER=unknown
#HAL_SENSING_ENABLED=true
#HAL_SENSING_INTERVAL=2.0              # Sensing loop poll interval (seconds)
#LAMP_CONFIG_PATH=/root/config/config.json
#LAMP_SENSING_URL=http://127.0.0.1:5000/api/sensing/event
#OPENCLAW_WORKSPACE=/root/.openclaw/workspace

# --- Device profile (which DEVICE.md / SOUL.md this body uses) ---
# DEVICES_DIR: path to the device-profile tree (devices/<type>/{DEVICE.md,SOUL.md}).
#   Shared with the Go os-server. On a flashed image point it at the bundled copy
#   (e.g. /opt/devices); unset in the repo resolves relative to os/hal.
#DEVICES_DIR=/opt/devices
# HAL_DEVICE_TYPE: device class = a folder name under DEVICES_DIR (lamp, intern, …).
#   Picks which DEVICE.md (capability mounting) + SOUL.md (persona) load. When
#   unset, falls back to config.json "device_type", then "lamp".
#HAL_DEVICE_TYPE=lamp

# --- Audio hardware overrides (leave blank to auto-detect) ---
# Run `arecord -l` / `aplay -l` to find card numbers. Format: plughw:<card>,<device>
#HAL_AUDIO_INPUT_ALSA=plughw:2,0
#HAL_AUDIO_OUTPUT_ALSA=plughw:1,0
#TTS_VOICE=nova                          # alloy, ash, coral, echo, fable, onyx, nova, sage, shimmer
#HAL_TTS_SPEED=1.3                    # 1.0=normal, max 4.0
#HAL_TTS_INSTRUCTIONS=                # Style/vibe prompt, e.g. "Speak warmly like a caring friend"
# Dedicated mic for ambient noise sensing (SoundPerception). Uses sounddevice device index.
# Run: python3 -c "import sounddevice; print(sounddevice.query_devices())" to list devices.
# If unset, falls back to the same device as HAL_AUDIO_INPUT_ALSA.
# Example: 2-mic setup — card 0 (seeed) for sensing, card 1 (USB) for STT
#HAL_AUDIO_SENSING_DEVICE=plughw:1,0
#HAL_AUDIO_OUTPUT_DEVICE=             # sounddevice index override (auto-derived from AUDIO_OUTPUT_ALSA if unset)

# --- Voice activity detection ---
#HAL_VAD_THRESHOLD=500       # RMS threshold; raise if noise triggers false detections
#HAL_SOUND_RMS_THRESHOLD=8000  # RMS threshold for "loud noise" sensing event; raise to reduce false triggers
#HAL_SILENCE_TIMEOUT=2.5     # Seconds of silence before STT session closes
#HAL_SPEECH_HOLDOFF=0.2      # Seconds of speech before STT connects; lower (0.05) for clean mics to avoid losing start of speech

# Secondary VAD filters (run after RMS gate, in order: webrtcvad → Silero)
# Pipeline: RMS → webrtcvad (fast C, ~0.1ms) → Silero ONNX (~20ms) → STT
# Enable both for maximum noise rejection; disable either to reduce CPU or latency.
#HAL_WEBRTCVAD_ENABLED=false           # Enable WebRTC VAD pre-filter (pip install webrtcvad)
#HAL_WEBRTCVAD_AGGRESSIVENESS=2        # 0 (lenient) to 3 (strict)
#HAL_SILERO_ENABLED=true               # Enable Silero ONNX VAD (model bundled in resources/)
#HAL_SILERO_THRESHOLD=0.3             # Speech confidence threshold (0.0–1.0); lower = more sensitive
#HAL_SILERO_CHUNK_SIZE=512            # Samples per Silero inference call
#HAL_WEBRTCVAD_FRAME_MS=30            # Frame size for webrtcvad (10, 20, or 30ms)
#HAL_SESSION_COOLDOWN_S=0.3           # Cooldown between STT sessions
#HAL_STT_KEEPALIVE=false              # Keep Deepgram WS open between sessions (lower latency, higher cost)

# --- Echo cancellation ---
#HAL_ECHO_RMS_FLOOR=200               # RMS must drop below this before re-enabling VAD
#HAL_ECHO_GATE_MAX_WAIT_S=1.5         # Max wait for reverb decay after TTS
#HAL_ECHO_GATE_WINDOW_S=0.05          # RMS check window (50ms)
#HAL_ECHO_SIMILARITY_THRESHOLD=0.55   # Transcript similarity above this = echo, drop it
#HAL_ECHO_RELEVANCE_WINDOW_S=15.0     # Only filter echoes within this window after TTS
#HAL_MAX_SESSION_DURATION_S=30        # Force-close STT session after this (prevent zombies)

# --- Voice barge-in (talk-to-interrupt during TTS) ---
# Off by default. Requires mic positioned so speaker bleed RMS stays well below
# user-voice RMS — typically achieved by physically separating mic from speaker
# OR using a hardware AEC mic (e.g. ReSpeaker XVF3800). On hardware without
# either, the bleed/voice ranges overlap and false-triggers are unavoidable.
# Tap-to-interrupt (button + TTP223 touchpad) still works regardless.
# Tune by tailing log for `max_rms_seen=` (peak per session) and `BARGE-IN: RMS=`
# events. Sweet spot: threshold midway between observed bleed-max and voice-min.
#HAL_BARGE_IN_ENABLED=false           # Master gate
#HAL_BARGE_IN_RMS_THRESHOLD=9000      # RMS that must be exceeded to trigger stop_tts()
#HAL_BARGE_IN_TRIGGER_FRAMES=1        # Consecutive blocks above threshold needed to fire
#HAL_BARGE_IN_BLOCK_MS=256            # Per-read block size; larger = less CPU but more latency

# --- Backchannel: active listening cues during STT ---
# Comma-separated filler words. Empty = feature disabled.
#HAL_BACKCHANNEL_FILLERS=Uhm,Ok,Ừ,Hmm
#HAL_BACKCHANNEL_STALL_S=8.0           # Partial unchanged for this long → play cue (high default so cue doesn't bleed into mic during speaker-ID capture; 0 = immediate)
#HAL_BACKCHANNEL_INTERVAL_S=6.0        # Min seconds between cues
#HAL_BACKCHANNEL_VOLUME=0.5            # Volume multiplier (0.0–1.0)

# --- Data layout ---
#HAL_POSE_MODEL_PATH=/root/local/models/rtmpose-m.onnx

# --- Camera stream ---
#HAL_CAMERA_STREAM_FPS=10             # MJPEG stream frame rate
#HAL_CAMERA_STREAM_WIDTH=320          # Stream resize width
#HAL_CAMERA_STREAM_JPEG_QUALITY=65    # JPEG compression quality (0-100)

# --- Sensing: Event cooldown ---
#HAL_EVENT_COOLDOWN_S=60.0            # Min seconds between events of the same type

# --- Sensing: Sound detection ---
#HAL_SOUND_SAMPLE_DURATION_S=0.5      # Sample window for sound level check

# --- Sensing: Light level detection ---
#HAL_LIGHT_LEVEL_INTERVAL_S=300.0     # Check every N seconds
#HAL_LIGHT_CHANGE_THRESHOLD=50        # Min brightness change (0-255) to trigger event

# --- Sensing: Face detection ---
#HAL_USERS_DIR=/root/local/users
#HAL_STRANGERS_DIR=/root/local/strangers
#HAL_YUNET_CONFIDENCE_THRESHOLD=0.5   # Min confidence for YuNet face detection (lower = catches blur/edge faces)
#HAL_FACE_COOLDOWN_S=10.0             # Min seconds between face presence events
#HAL_FACE_OWNER_FORGET_S=1800.0       # Re-fire presence after N seconds without seeing owner
#HAL_FACE_STRANGER_FORGET_S=1800.0    # Same for strangers (30 min)
#HAL_FACE_STRANGER_FLUSH_S=10.0       # Flush stranger snapshots interval
#HAL_FACE_AREA_RATIO_THRESHOLD=0.05   # Skip faces smaller than this fraction of frame area (too far / unreliable)

# --- Vision tracking (/servo/track) ---
#HAL_TRACKING_DETECT_LOCAL=true       # Use local YOLOv8n for COCO targets (false → force remote YOLOWorld)
#HAL_TRACKING_FACE_DETECTOR=true      # Use local YuNet for target='face' (false → fall back to remote YOLOWorld)

# --- Camera snapshot (/camera/snapshot?save=true) ---
# Must be inside one of OpenClaw's allowed media roots (default: state/configDir
# under /root/.openclaw — `media/`, `workspace/`, `canvas/`, `sandboxes/`).
# Outside roots → image tool returns "Local media path is not under an allowed
# directory" and the agent has to cp the file before analyzing.
#HAL_SNAPSHOT_DIR=/root/.openclaw/media/lamp-snapshots

# --- Sensing: Motion detection (remote DL backend) ---
#HAL_MOTION_ENABLED=true
#HAL_MOTION_PER_FACE_ENABLED=false       # per-face action recognition (separate WS session per detected face)
#HAL_MOTION_PER_FACE_DEDUP_WINDOW_S=300  # per-action dedup window per face (5 min)
#HAL_MOTION_PER_FACE_SESSION_TTL_S=30    # evict face WS session after N seconds without seeing that face
#HAL_MOTION_CONFIDENCE_THRESHOLD=0.3
#HAL_MOTION_FLUSH_S=10.0
#HAL_MOTION_EVENT_COOLDOWN_S=360.0
#HAL_MOTION_PERSON_DETECTION_ENABLED=true  # toggle person detection before action recognition (sent to dlbackend)
#HAL_MOTION_PERSON_MIN_AREA_RATIO=0.25    # skip persons covering less than 1/4 of frame (sent to dlbackend)
#HAL_MOTION_SNAPSHOT_DIR=/tmp/lamp-motion-snapshots
#HAL_MOTION_SNAPSHOT_MAX_COUNT=100

# --- Sensing: Emotion detection (remote DL backend) ---
#HAL_EMOTION_ENABLED=true
#HAL_EMOTION_CONFIDENCE_THRESHOLD=0.5
#HAL_EMOTION_FLUSH_S=10.0
#HAL_EMOTION_SNAPSHOT_DIR=/tmp/lamp-emotion-snapshots
#HAL_EMOTION_SNAPSHOT_MAX_COUNT=100

# --- DL backend connection ---
#DL_BACKEND_URL=                         # Base WS URL, e.g. wss://<pod>-8888.proxy.runpod.net/lelamp
#DL_API_KEY=                             # Shared secret for X-API-Key auth
#DL_MOTION_ENDPOINT=/api/dl/action-analysis/ws    # Appended to DL_BACKEND_URL
#DL_EMOTION_ENDPOINT=/api/dl/emotion-analysis/ws  # Appended to DL_BACKEND_URL
#DL_SPEAKER_ENDPOINT=/api/dl/audio-recognizer/embed  # Appended to DL_BACKEND_URL
#HAL_DL_HEARTBEAT_INTERVAL_S=60.0     # WebSocket heartbeat interval (seconds)

# --- DL backend encryption (RSA + AES-256-GCM) ---
#HAL_DL_ENCRYPTION=false              # Enable client-side encryption for DL backend
#HAL_DL_ENCRYPTION_REQUIRED=false     # Fail if encryption setup fails (no plaintext fallback)
#DL_PUBLIC_KEY_FILE=                     # Path to RSA public key PEM file (if set, skips fetching from LB)
#DL_PUBLIC_KEY_ENDPOINT=/crypto/public-key  # Appended to DL_BACKEND_URL to fetch public key

# --- Sensing: Speaker recognition (voice embedding via dlbackend) ---
#HAL_SPEAKER_RECOGNITION_ENABLED=true
#HAL_SPEAKER_MIN_AUDIO_S=0.8          # Min audio duration (seconds) for speaker embedding
#SPEAKER_MATCH_THRESHOLD=0.7             # Cosine similarity threshold for speaker match (0.0-1.0)
#SPEAKER_ENROLL_CONSISTENCY_THRESHOLD=0.7 # Min consistency between enrollment samples
#SPEAKER_EMBEDDING_API_TIMEOUT_S=15      # Timeout for embedding API call (seconds)
#HAL_UNKNOWN_AUDIO_DIR=/tmp/lamp-unknown-voice  # Where unknown speaker audio is saved
#HAL_VOICE_STRANGERS_DIR=/root/local/voice_strangers  # Persisted stranger centroid state (embeds/labels/counter .npy)
# All thresholds below are SCALED cosine in [0, 1] (`(raw + 1) / 2`), same
# unit as SPEAKER_MATCH_THRESHOLD. Ordering: CLUSTER_MERGE < STRANGER_MATCH
# < MATCH = CONSISTENCY. Defaults sit just below the EER band so same-
# speaker-different-distance doesn't fragment into multiple clusters.
#HAL_VOICE_STRANGER_MATCH_THRESHOLD=0.675  # Scaled cosine to reuse same voice_<N> for new unknown utterance
#HAL_MAX_VOICE_STRANGERS=50                # Cap on tracked stranger clusters (oldest evicted first)
#HAL_CLUSTER_MERGE_THRESHOLD=0.625         # Scaled cosine to auto-merge fragmented clusters on enroll (looser; consistency filter catches false merges)
#HAL_SPEAKER_CHUNK_SECONDS=3.0             # Chunk window for /embed; longer = smoother per-chunk emb but fewer votes
#HAL_ENROLL_NUDGE_COOLDOWN_S=1800          # Per-cluster cooldown for enroll nudge (seconds, default 30 min)

# --- Sensing: Pose-based motion detection (RTMPose) ---
#HAL_POSE_MOTION_ENABLED=true
#HAL_POSE_MOTION_ANGLE_THRESHOLD=30.0  # Min arm joint angle change (degrees)

# --- Sensing: Snapshot storage ---
#HAL_SNAPSHOT_TMP_DIR=/tmp/lamp-sensing-snapshots
#HAL_SNAPSHOT_TMP_MAX_COUNT=50
#HAL_SNAPSHOT_PERSIST_DIR=/var/lib/hal/snapshots
#HAL_SNAPSHOT_PERSIST_TTL_S=259200     # 72 hours
#HAL_SNAPSHOT_PERSIST_MAX_BYTES=52428800  # 50 MB

# --- Presence: Auto light on/off ---
#HAL_IDLE_TIMEOUT_S=300               # Seconds before dim
#HAL_AWAY_TIMEOUT_S=900               # Seconds before off
#HAL_IDLE_BRIGHTNESS=0.20

# --- Realtime voice agent ---
#HAL_REALTIME_ENABLED=false             # Master gate for the realtime voice pipeline
#HAL_REALTIME_PROVIDER=none             # none | gemini | openai
# Turn detection / VAD: "server_vad" | "semantic_vad" | "off"
# For Gemini: "off" disables automatic activity detection; any other value enables it.
# For OpenAI: maps to turn_detection type in session config.
#HAL_REALTIME_TURN_DETECTION=off

# --- Realtime: Gemini Live ---
#GEMINI_API_KEY=
#HAL_GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
#HAL_GEMINI_LIVE_VOICE=Kore             # Puck | Charon | Kore | Fenrir | Aoede
#HAL_GEMINI_THINKING_LEVEL=HIGH         # MINIMAL | LOW | MEDIUM | HIGH
#HAL_GEMINI_USE_LANGUAGE_CODES=false    # Only for Enterprise Agent Platform mode

# --- Realtime: OpenAI Realtime ---
#OPENAI_API_KEY=
#HAL_OPENAI_REALTIME_MODEL=gpt-realtime-2
#HAL_OPENAI_REALTIME_VOICE=alloy        # alloy | ash | ballad | coral | echo | sage | shimmer | verse | marin | cedar
#HAL_OPENAI_REASONING_EFFORT=xhigh     # minimal | low | medium | high | xhigh

# --- Realtime: Context manager ---
#HAL_OPENCLAW_WORKSPACE_DIR=/root/.openclaw/workspace
#HAL_REALTIME_MEMORY_PATH=/tmp/realtime_memory.jsonl
#HAL_REALTIME_MAX_MEMORY_ENTRIES=1000   # Max entries in realtime memory JSONL
#HAL_REALTIME_MEMORY_TRIM_KEEP=500     # Keep this many when trimming
#HAL_REALTIME_LAMP_MEMORY_COUNT=20     # Latest N lamp memory files to load
#HAL_REALTIME_MEMORY_COUNT=20          # Latest N realtime memory entries to load

# --- CPU / thread tuning (important for Raspberry Pi) ---
OMP_NUM_THREADS=1               # Limit OpenMP threads used by onnxruntime/numpy — prevents thread pool from spinning all 4 Pi cores
OPENBLAS_NUM_THREADS=1          # Same for OpenBLAS (used by numpy/scipy)
